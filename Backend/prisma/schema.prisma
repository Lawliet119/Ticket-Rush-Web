  locked_at  DateTime @default(now()) @db.Timestamptz(6)
  expires_at DateTime @db.Timestamptz(6)
  seats      seats    @relation(fields: [seat_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_seat_locks_seat")
