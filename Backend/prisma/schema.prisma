generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]

}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model events {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                  String                  @db.VarChar(300)
  description            String?
  venue                  String                  @db.VarChar(300)
  address                String?
  event_date             DateTime                @db.Timestamptz(6)
  event_end_date         DateTime?               @db.Timestamptz(6)
  sale_start_at          DateTime                @db.Timestamptz(6)
  sale_end_at            DateTime                @db.Timestamptz(6)
  status                 event_status            @default(DRAFT)
  banner_url             String?                 @db.VarChar(500)
  total_seats            Int                     @default(0)
  available_seats        Int                     @default(0)
  is_virtual_queue       Boolean                 @default(false)
  created_by             String                  @db.Uuid
  created_at             DateTime                @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                @default(now()) @db.Timestamptz(6)
  users                  users                   @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "fk_events_created_by")
  orders                 orders[]
  virtual_queue_sessions virtual_queue_sessions?
  zones                  zones[]

  @@index([created_by], map: "idx_events_created_by")
  @@index([event_date], map: "idx_events_event_date")
  @@index([sale_start_at], map: "idx_events_sale_start")
  @@index([status], map: "idx_events_status")
  @@index([status, sale_start_at, sale_end_at], map: "idx_events_status_sale")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model order_items {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String   @db.Uuid
  seat_id    String   @db.Uuid
  price      Decimal  @db.Decimal(12, 2)
  zone_name  String   @db.VarChar(100)
  seat_label String   @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order_items_order")
  seats      seats    @relation(fields: [seat_id], references: [id], onUpdate: NoAction, map: "fk_order_items_seat")
  tickets    tickets?

  @@index([order_id], map: "idx_order_items_order")
  @@index([seat_id], map: "idx_order_items_seat")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model orders {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String        @db.Uuid
  event_id     String        @db.Uuid
  order_code   String        @unique(map: "uq_orders_code") @db.VarChar(20)
  total_amount Decimal       @db.Decimal(15, 2)
  status       order_status  @default(PENDING)
  expires_at   DateTime      @db.Timestamptz(6)
  paid_at      DateTime?     @db.Timestamptz(6)
  cancelled_at DateTime?     @db.Timestamptz(6)
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime      @default(now()) @db.Timestamptz(6)
  order_items  order_items[]
  events       events        @relation(fields: [event_id], references: [id], onUpdate: NoAction, map: "fk_orders_event")
  users        users         @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_orders_user")
  tickets      tickets[]

  @@index([event_id], map: "idx_orders_event")
  @@index([status, expires_at], map: "idx_orders_pending_expires", where: raw("(status = 'PENDING'::order_status)"))
  @@index([status], map: "idx_orders_status")
  @@index([user_id], map: "idx_orders_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model queue_tokens {
  id                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id             String                 @db.Uuid
  user_id                String                 @db.Uuid
  position               Int
  status                 queue_status           @default(WAITING)
  access_token           String?                @unique(map: "idx_qt_access_token", where: raw("(access_token IS NOT NULL)")) @db.VarChar(128)
  granted_at             DateTime?              @db.Timestamptz(6)
  expires_at             DateTime?              @db.Timestamptz(6)
  created_at             DateTime               @default(now()) @db.Timestamptz(6)
  virtual_queue_sessions virtual_queue_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_qt_session")
  users                  users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_qt_user")

  @@unique([session_id, user_id], map: "uq_qt_session_user")
  @@index([session_id, position], map: "idx_qt_session_position")
  @@index([session_id, status], map: "idx_qt_session_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model seat_locks {
