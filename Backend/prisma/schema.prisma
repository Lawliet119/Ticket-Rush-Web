/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model seats {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  zone_id     String        @db.Uuid
  row_number  Int
  seat_number Int
  label       String        @db.VarChar(20)
  status      seat_status   @default(AVAILABLE)
  version     Int           @default(1)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @default(now()) @db.Timestamptz(6)
  order_items order_items[]
  seat_locks  seat_locks?
  zones       zones         @relation(fields: [zone_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_seats_zone")

  @@unique([zone_id, row_number, seat_number], map: "uq_seats_position")
  @@index([zone_id], map: "idx_seats_available", where: raw("(status = 'AVAILABLE'::seat_status)"))
  @@index([zone_id, status], map: "idx_seats_zone_status")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model tickets {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id      String        @db.Uuid
  order_item_id String        @unique(map: "uq_tickets_order_item") @db.Uuid
  user_id       String        @db.Uuid
  ticket_code   String        @unique(map: "uq_tickets_code") @db.VarChar(30)
  qr_data       String        @unique(map: "uq_tickets_qr")
  status        ticket_status @default(ACTIVE)
  issued_at     DateTime      @default(now()) @db.Timestamptz(6)
  used_at       DateTime?     @db.Timestamptz(6)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  orders        orders        @relation(fields: [order_id], references: [id], onUpdate: NoAction, map: "fk_tickets_order")
  order_items   order_items   @relation(fields: [order_item_id], references: [id], onUpdate: NoAction, map: "fk_tickets_order_item")
  users         users         @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_tickets_user")

  @@index([order_id], map: "idx_tickets_order")
  @@index([status], map: "idx_tickets_status")
  @@index([user_id], map: "idx_tickets_user")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique(map: "uq_users_email") @db.VarChar(255)
  password_hash String         @db.VarChar(255)
  role          user_role      @default(CUSTOMER)
  full_name     String         @db.VarChar(150)
  date_of_birth DateTime?      @db.Date
  gender        gender?
  phone         String?        @db.VarChar(20)
  avatar_url    String?        @db.VarChar(500)
  is_active             Boolean        @default(true)
  password_reset_token  String?        @db.VarChar(255)
  password_reset_expires DateTime?     @db.Timestamptz(6)
  created_at            DateTime       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime       @default(now()) @db.Timestamptz(6)
  events        events[]
  orders        orders[]
  queue_tokens  queue_tokens[]
  seat_locks    seat_locks[]
  tickets       tickets[]
  key_tokens    key_tokens[]

  @@index([gender], map: "idx_users_gender", where: raw("(gender IS NOT NULL)"))
  @@index([role], map: "idx_users_role")
}

