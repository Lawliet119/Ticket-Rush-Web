/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model zones {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id      String   @db.Uuid
  name          String   @db.VarChar(100)
  description   String?  @db.VarChar(300)
  rows          Int
  seats_per_row Int
  price         Decimal  @db.Decimal(12, 2)
  color_hex     String   @default("#3B82F6") @db.VarChar(7)
  sort_order    Int      @default(0)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  seats         seats[]
  events        events   @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_zones_event")

  @@unique([event_id, name], map: "uq_zones_event_name")
  @@index([event_id], map: "idx_zones_event_id")
}

enum event_status {
  DRAFT
  PUBLISHED
  ON_SALE
  SOLD_OUT
  COMPLETED
  CANCELLED
}

enum gender {
  MALE
  FEMALE
  OTHER
}

enum order_status {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

enum queue_status {
  WAITING
  GRANTED
  ENTERED
  EXPIRED
  LEFT
}

enum seat_status {
  AVAILABLE
  LOCKED
  SOLD
}

enum ticket_status {
  ACTIVE
  USED
  CANCELLED
}

enum user_role {
  CUSTOMER
  ADMIN
}

/// Bảng quản lý Token hỗ trợ JWT và phòng chống Hacker (Token Reuse Detection)
model key_tokens {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String   @unique(map: "uq_key_token_user") @db.Uuid
  public_key          String   // Lưu Public Key ( dạng thô string )
  private_key         String?  // Lưu Private Key (Có thể nullable nếu bạn thiết kế không lưu)
  refresh_token       String?  // Refresh Token đang được active
  refresh_tokens_used String[] @default([]) // Mảng lưu các token đã dùng (Dành cho chức năng phát hiện đánh cắp)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @db.Timestamptz(6)

  users               users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_key_tokens_user")

  @@index([user_id], map: "idx_key_tokens_user")
}
